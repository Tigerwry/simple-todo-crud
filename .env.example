# ---- MySQL Database Configuration ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=todo_app

# ---- Security ----
# Number of bcrypt salt rounds used to hash passwords
BCRYPT_SALT_ROUNDS=10

# ---- Web server (frontend + REST API) ----
# Port the Express server listens on (console app ignores this)
PORT=3000
# Secret used to sign JWT session tokens — change this in production!
JWT_SECRET=change-this-to-a-long-random-string
